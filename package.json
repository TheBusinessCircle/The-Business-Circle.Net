{
  "name": "the-business-circle-network",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "deps:check:critical": "npm outdated next-auth @auth/prisma-adapter prisma @prisma/client @prisma/adapter-pg",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "email:test": "tsx scripts/test-email.ts",
    "docker:up": "docker compose up -d --build",
    "docker:up:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "docker:down": "docker compose down",
    "docker:down:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:logs": "docker compose logs -f app",
    "docker:logs:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f app",
    "docker:generate": "docker compose exec app npx prisma generate",
    "docker:migrate": "docker compose exec app npx prisma migrate deploy",
    "docker:seed": "docker compose exec app npm run db:seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.7.2",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.35.3",
    "ably": "^2.19.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "next": "15.1.3",
    "next-auth": "5.0.0-beta.25",
    "pg": "^8.16.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.53.2",
    "resend": "^6.9.3",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.1.3",
    "postcss": "^8.4.49",
    "prisma": "7.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
