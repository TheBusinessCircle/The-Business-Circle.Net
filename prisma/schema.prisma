generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                             String                       @id @default(cuid())
  name                           String?
  email                          String                       @unique
  emailVerified                  DateTime?
  verificationEmailLastSentAt    DateTime?
  verificationEmailSendCount     Int                          @default(0)
  image                          String?
  passwordHash                   String?
  role                           Role                         @default(MEMBER)
  memberRoleTag                  MemberRoleTag                @default(FOUNDER)
  membershipTier                 MembershipTier               @default(FOUNDATION)
  foundingMember                 Boolean                      @default(false)
  foundingTier                   MembershipTier?
  foundingPrice                  Int?
  foundingClaimedAt              DateTime?
  acceptedTermsAt                DateTime?
  acceptedRulesAt                DateTime?
  acceptedTermsVersion           String?
  acceptedRulesVersion           String?
  registrationSource             String?
  suspended                      Boolean                      @default(false)
  suspendedAt                    DateTime?
  createdAt                      DateTime                     @default(now())
  updatedAt                      DateTime                     @updatedAt
  accounts                       Account[]
  createdChannels                Channel[]                    @relation("ChannelCreator")
  handledContacts                ContactSubmission[]          @relation("SubmissionHandler")
  submittedContacts              ContactSubmission[]          @relation("SubmissionAuthor")
  hostedEvents                   Event[]                      @relation("EventHost")
  communityComments              CommunityComment[]
  communityCommentLikes          CommunityCommentLike[]
  communityPostLikes             CommunityPostLike[]
  communityPosts                 CommunityPost[]
  communityPromptEvents          CommunityPromptEvent[]       @relation("CommunityPromptActor")
  blueprintVotes                 BlueprintVote[]
  blueprintDiscussionComments    BlueprintDiscussionComment[]
  blueprintDiscussionLikes       BlueprintDiscussionLike[]
  directMessageRequestsSent      DirectMessageRequest[]       @relation("DirectMessageRequestsSent")
  directMessageRequestsReceived  DirectMessageRequest[]       @relation("DirectMessageRequestsReceived")
  directMessageThreads           DirectMessageParticipant[]
  directMessagesSent             DirectMessage[]              @relation("DirectMessagesSent")
  directMessageBlocksCreated     DirectMessageBlock[]         @relation("DirectMessageBlocksCreated")
  directMessageBlocksReceived    DirectMessageBlock[]         @relation("DirectMessageBlocksReceived")
  directMessageReportsFiled      DirectMessageReport[]        @relation("DirectMessageReportsFiled")
  directMessageReportsTargetUser DirectMessageReport[]        @relation("DirectMessageReportsTargetUser")
  directMessageReportsResolvedBy DirectMessageReport[]        @relation("DirectMessageReportsResolvedBy")
  winsAuthored                   Win[]                        @relation("WinsAuthored")
  winParticipations              WinParticipant[]
  moderationActionsByAdmin       ModerationAuditLog[]         @relation("ModerationActionsByAdmin")
  messages                       Message[]
  founderServiceRequests         FounderServiceRequest[]
  foundingMembership             FoundingMember?
  foundingReservations           FoundingOfferReservation[]
  inviteCodeRedemptions          InviteCodeRedemption[]
  createdLaunchCodes             LaunchCode[]                 @relation("LaunchCodeCreator")
  launchCodeRedemptions          LaunchCodeRedemption[]
  completedPendingRegistration   PendingRegistration?         @relation("PendingRegistrationCompletedUser")
  memberInvite                   MemberInvite?
  inviteReferralsSent            InviteReferral[]             @relation("InviteReferrer")
  inviteReferralReceived         InviteReferral?              @relation("InviteReferred")
  reputationScore                ReputationScore?
  reputationEvents               ReputationEvent[]
  userBadges                     UserBadge[]
  innerCircleQuestions           InnerCircleQuestion[]        @relation("InnerCircleQuestionAuthor")
  answeredInnerCircleQuestions   InnerCircleQuestion[]        @relation("InnerCircleQuestionAnswerer")
  profile                        Profile?
  resourcesAuthored              Resource[]                   @relation("ResourceAuthor")
  resourcesApproved              Resource[]                   @relation("ResourceApprover")
  resourcesRejected              Resource[]                   @relation("ResourceRejector")
  resourcesLocked                Resource[]                   @relation("ResourceLocker")
  siteVisitors                   SiteVisitor[]
  sitePageViews                  SitePageView[]
  siteEvents                     SiteEvent[]
  founderAuditSubmissions        FounderAuditSubmission[]
  dailyResourceBatchesGenerated  DailyResourceBatch[]         @relation("DailyResourceBatchGenerator")
  dailyResourceBatchesApproved   DailyResourceBatch[]         @relation("DailyResourceBatchApprover")
  resourceReads                  ResourceRead[]
  passwordResetTokens            PasswordResetToken[]
  sessions                       Session[]
  subscription                   Subscription?
  createdCallRooms               CallRoom[]                   @relation("CallRoomCreator")
  hostedCallRooms                CallRoom[]                   @relation("CallRoomHost")
  callParticipations             CallParticipant[]
  callHostPermission             CallHostPermission?
  grantedCallHostPermissions     CallHostPermission[]         @relation("CallHostPermissionGrantor")
  groupHostAccessRequests        GroupHostAccessRequest[]     @relation("GroupHostRequestUser")
  reviewedGroupHostRequests      GroupHostAccessRequest[]     @relation("GroupHostRequestReviewer")
  hostedCallSchedules            CallSchedule[]               @relation("CallScheduleHost")
  callAuditLogs                  CallAuditLog[]               @relation("CallAuditActor")
  targetedCallAuditLogs          CallAuditLog[]               @relation("CallAuditTarget")
  redeemedDiscounts              BillingDiscount[]            @relation("BillingDiscountRedeemer")
  memberTestimonials             Testimonial[]                @relation("MemberTestimonials")
  requestedTestimonials          Testimonial[]                @relation("TestimonialRequestedByAdmin")
  approvedTestimonials           Testimonial[]                @relation("TestimonialApprovedByAdmin")
  submittedTestimonials          Testimonial[]                @relation("TestimonialSubmittedByUser")
  reviewApprovedTestimonials     Testimonial[]                @relation("TestimonialApprovedByUser")
  circleCards                    CircleCard[]
  circleWalletContacts           CircleWalletContact[]
  circleCardEvents               CircleCardEvent[]

  @@index([role])
  @@index([memberRoleTag])
  @@index([membershipTier])
  @@index([foundingMember])
  @@index([foundingTier])
  @@index([registrationSource])
  @@index([suspended])
  @@index([createdAt])
  @@index([suspended, createdAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedIp String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([createdAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([identifier])
}

model SiteVisitor {
  id                     String                    @id @default(cuid())
  anonymousId            String                    @unique
  firstSeenAt            DateTime                  @default(now())
  lastSeenAt             DateTime                  @default(now())
  visitCount             Int                       @default(0)
  userId                 String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  user                   User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessions               SiteSession[]
  pageViews              SitePageView[]
  events                 SiteEvent[]
  founderAuditSubmissions FounderAuditSubmission[]
  launchCodeRedemptions LaunchCodeRedemption[]

  @@index([userId])
  @@index([createdAt])
  @@index([lastSeenAt])
}

model SiteSession {
  id                     String                    @id @default(cuid())
  visitorId              String
  startedAt              DateTime                  @default(now())
  endedAt                DateTime?
  entryPath              String
  exitPath               String?
  referrer               String?
  source                 String?
  medium                 String?
  campaign               String?
  deviceType             String?
  browser                String?
  os                     String?
  country                String?
  city                   String?
  isBot                  Boolean                   @default(false)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  visitor                SiteVisitor               @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  pageViews              SitePageView[]
  events                 SiteEvent[]
  founderAuditSubmissions FounderAuditSubmission[]

  @@index([visitorId])
  @@index([startedAt])
  @@index([endedAt])
  @@index([source])
  @@index([isBot])
  @@index([createdAt])
}

model SitePageView {
  id           String       @id @default(cuid())
  visitorId    String
  sessionId    String?
  userId       String?
  path         String
  title        String?
  referrer     String?
  searchParams String?
  deviceType   String?
  browser      String?
  os           String?
  createdAt    DateTime     @default(now())
  visitor      SiteVisitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  session      SiteSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([visitorId])
  @@index([sessionId])
  @@index([userId])
  @@index([path])
  @@index([createdAt])
}

model SiteEvent {
  id        String       @id @default(cuid())
  visitorId String?
  sessionId String?
  userId    String?
  eventName String
  path      String?
  metadata  Json?
  createdAt DateTime     @default(now())
  visitor   SiteVisitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  session   SiteSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([visitorId])
  @@index([sessionId])
  @@index([userId])
  @@index([eventName])
  @@index([path])
  @@index([createdAt])
}

model FounderAuditSubmission {
  id              String       @id @default(cuid())
  visitorId       String?
  userId          String?
  sessionId       String?
  score           Int
  resultType      String
  recommendedTier String?
  answers         Json
  strengths       Json?
  weaknesses      Json?
  sourcePath      String?
  referrer        String?
  createdAt       DateTime     @default(now())
  visitor         SiteVisitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  session         SiteSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([visitorId])
  @@index([userId])
  @@index([sessionId])
  @@index([resultType])
  @@index([recommendedTier])
  @@index([createdAt])
}

model GrowthIntelligenceReport {
  id                 String   @id @default(cuid())
  range              String
  generatedAt        DateTime
  nextRefreshAt      DateTime
  headline           String
  summary            String   @db.Text
  healthScore        Int?
  momentumLabel      String?
  keyFindings        Json
  risks              Json
  opportunities      Json
  recommendedActions Json
  priorityAction     String?  @db.Text
  metricsSnapshot    Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([generatedAt])
  @@index([nextRefreshAt])
  @@index([range])
}

model Profile {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  headline                   String?
  bio                        String?
  location                   String?
  experience                 String?
  website                    String?
  instagram                  String?
  linkedin                   String?
  tiktok                     String?
  facebook                   String?
  youtube                    String?
  customLinks                String[]  @default([])
  accentTheme                String?
  workspaceAtmosphereEnabled Boolean   @default(false)
  collaborationNeeds         String?
  collaborationOffers        String?
  partnershipInterests       String?
  collaborationTags          String[]  @default([])
  isPublic                   Boolean   @default(true)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  business                   Business?
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([location])
  @@index([isPublic])
  @@index([updatedAt])
}

model Business {
  id            String          @id @default(cuid())
  profileId     String          @unique
  status        BusinessStatus?
  companyName   String?
  companyNumber String?
  slug          String?         @unique
  description   String?
  industry      String?
  services      String?
  stage         BusinessStage?
  location      String?
  website       String?
  teamSize      Int?
  foundedYear   Int?
  isPublic      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  profile       Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([industry])
  @@index([status])
  @@index([stage])
  @@index([location])
  @@index([isPublic])
}

model CircleCard {
  id              String                @id @default(cuid())
  userId          String
  slug            String                @unique
  fullName        String
  businessName    String?
  role            String?
  tagline         String?
  about           String?               @db.Text
  profileImageUrl String?
  websiteUrl      String?
  email           String?
  phone           String?
  location        String?
  socialLinks     Json                  @default("{}")
  isPrimary       Boolean               @default(false)
  isPublished     Boolean               @default(true)
  viewCount       Int                   @default(0)
  qrCodeUrl       String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletContacts  CircleWalletContact[]
  events          CircleCardEvent[]

  @@index([userId])
  @@index([isPublished])
}

model CircleCardEvent {
  id        String              @id @default(cuid())
  cardId    String
  eventType CircleCardEventType
  visitorId String?
  userId    String?
  metadata  Json?
  createdAt DateTime            @default(now())
  card      CircleCard          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cardId, eventType, createdAt])
  @@index([cardId, createdAt])
  @@index([eventType, createdAt])
  @@index([visitorId, createdAt])
  @@index([userId, createdAt])
}

model CircleWalletContact {
  id        String     @id @default(cuid())
  userId    String
  cardId    String
  savedAt   DateTime   @default(now())
  favourite Boolean    @default(false)
  notes     String?    @db.Text
  tags      Json       @default("[]")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  card      CircleCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
  @@index([savedAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  colorHex    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  resources   Resource[]

  @@index([isActive, sortOrder])
}

model Resource {
  id                   String                   @id @default(cuid())
  title                String
  slug                 String                   @unique
  content              String                   @default("") @db.Text
  excerpt              String                   @default("")
  tier                 ResourceTier             @default(FOUNDATION)
  category             String                   @default("Getting Started")
  type                 ResourceType             @default(CLARITY)
  summary              String
  coverImage           String?
  stage                ResourceStage            @default(STARTUP)
  status               ResourceStatus           @default(DRAFT)
  accessTier           MembershipTier           @default(FOUNDATION)
  mediaType            ResourceMediaType        @default(NONE)
  mediaUrl             String?
  categoryId           String?
  authorId             String?
  estimatedReadMinutes Int?
  scheduledFor         DateTime?
  publishedAt          DateTime?
  archivedAt           DateTime?
  approvalStatus       ResourceApprovalStatus   @default(MANUAL)
  generationSource     ResourceGenerationSource @default(MANUAL)
  generationBatchId    String?
  generationDate       DateTime?                @db.Date
  imageDirection       String?
  imagePrompt          String?                  @db.Text
  imageStatus          ResourceImageStatus      @default(MANUAL)
  generatedImageUrl    String?
  generationMetadata   Json?
  approvedAt           DateTime?
  approvedById         String?
  rejectedAt           DateTime?
  rejectedById         String?
  lockedAt             DateTime?
  lockedById           String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  author               User?                    @relation("ResourceAuthor", fields: [authorId], references: [id])
  approvedBy           User?                    @relation("ResourceApprover", fields: [approvedById], references: [id])
  rejectedBy           User?                    @relation("ResourceRejector", fields: [rejectedById], references: [id])
  lockedBy             User?                    @relation("ResourceLocker", fields: [lockedById], references: [id])
  generationBatch      DailyResourceBatch?      @relation(fields: [generationBatchId], references: [id], onDelete: SetNull)
  catalogCategory      Category?                @relation(fields: [categoryId], references: [id])
  blocks               ResourceBlock[]
  readStates           ResourceRead[]
  tags                 ResourceTag[]

  @@index([tier])
  @@index([status])
  @@index([scheduledFor])
  @@index([status, tier])
  @@index([status, accessTier])
  @@index([categoryId])
  @@index([authorId])
  @@index([publishedAt])
  @@index([status, publishedAt])
  @@index([createdAt])
  @@index([approvalStatus])
  @@index([imageStatus])
  @@index([generationBatchId])
  @@index([generationDate])
  @@index([generationSource])
  @@index([approvedById])
  @@index([rejectedById])
  @@index([lockedById])
}

model DailyResourceBatch {
  id             String                   @id @default(cuid())
  generationDate DateTime                 @unique @db.Date
  status         DailyResourceBatchStatus @default(DRAFT)
  generatedAt    DateTime                 @default(now())
  generatedById  String?
  approvedAt     DateTime?
  approvedById   String?
  scheduledAt    DateTime?
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  generatedBy    User?                    @relation("DailyResourceBatchGenerator", fields: [generatedById], references: [id], onDelete: SetNull)
  approvedBy     User?                    @relation("DailyResourceBatchApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  resources      Resource[]

  @@index([status])
  @@index([generatedAt])
  @@index([generatedById])
  @@index([approvedById])
}

model ResourceRead {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  readAt     DateTime @default(now())
  updatedAt  DateTime @updatedAt
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId, readAt])
  @@index([resourceId, readAt])
}

model ResourceBlock {
  id         String            @id @default(cuid())
  resourceId String
  type       ResourceBlockType
  heading    String?
  position   Int
  content    Json
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  resource   Resource          @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, position])
  @@index([resourceId, type])
}

model ResourceTag {
  id         String   @id @default(cuid())
  resourceId String
  name       String
  slug       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, slug])
  @@index([resourceId])
  @@index([slug])
  @@index([name])
}

model Channel {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  description           String?
  topic                 String?
  accessTier            MembershipTier         @default(FOUNDATION)
  accessLevel           ChannelAccessLevel     @default(MEMBERS)
  position              Int                    @default(0)
  allowAutomatedPrompts Boolean                @default(true)
  isPrivate             Boolean                @default(false)
  isArchived            Boolean                @default(false)
  createdById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  communityPosts        CommunityPost[]
  promptEvents          CommunityPromptEvent[]
  createdBy             User?                  @relation("ChannelCreator", fields: [createdById], references: [id])
  messages              Message[]

  @@index([accessTier])
  @@index([accessLevel, position])
  @@index([isPrivate])
  @@index([isArchived])
  @@index([isArchived, accessTier, position])
  @@index([createdById])
}

model Message {
  id              String    @id @default(cuid())
  channelId       String
  userId          String
  parentMessageId String?
  content         String
  attachments     Json?
  isEdited        Boolean   @default(false)
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  channel         Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parentMessage   Message?  @relation("MessageReplies", fields: [parentMessageId], references: [id])
  replies         Message[] @relation("MessageReplies")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([userId, createdAt])
  @@index([parentMessageId])
}

model Event {
  id          String           @id @default(cuid())
  title       String
  slug        String?          @unique
  description String?
  accessTier  MembershipTier   @default(FOUNDATION)
  accessLevel EventAccessLevel @default(MEMBERS)
  startAt     DateTime
  endAt       DateTime?
  timezone    String           @default("UTC")
  location    String?
  hostName    String?
  meetingLink String?
  replayUrl   String?
  capacity    Int?
  isCancelled Boolean          @default(false)
  hostId      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  host        User?            @relation("EventHost", fields: [hostId], references: [id])

  @@index([accessTier])
  @@index([accessLevel])
  @@index([startAt, accessTier])
  @@index([hostId])
  @@index([isCancelled])
  @@index([isCancelled, startAt])
}

model CallRoom {
  id                   String            @id @default(cuid())
  type                 CallRoomType
  status               CallRoomStatus    @default(SCHEDULED)
  createdByUserId      String
  hostUserId           String
  title                String
  description          String?
  slug                 String            @unique
  livekitRoomName      String            @unique
  tierVisibility       CallAudienceScope @default(FOUNDATION)
  customTierVisibility MembershipTier[]  @default([])
  maxParticipants      Int
  hostLevelRequired    Int?
  startsAt             DateTime?
  startedAt            DateTime?
  endedAt              DateTime?
  isRecorded           Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  createdBy            User              @relation("CallRoomCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  hostUser             User              @relation("CallRoomHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  participants         CallParticipant[]
  schedule             CallSchedule?
  auditLogs            CallAuditLog[]

  @@index([type, status])
  @@index([hostUserId, status])
  @@index([createdByUserId, createdAt])
  @@index([status, startsAt])
  @@index([tierVisibility, status])
}

model CallParticipant {
  id              String                       @id @default(cuid())
  roomId          String
  userId          String
  role            CallParticipantRole          @default(MEMBER)
  presenceState   CallParticipantPresenceState @default(INVITED)
  livekitIdentity String?
  joinedAt        DateTime?
  leftAt          DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  room            CallRoom                     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId, presenceState])
  @@index([userId, createdAt])
  @@index([livekitIdentity])
}

model CallHostPermission {
  id                    String           @id @default(cuid())
  userId                String           @unique
  canHostGroupCalls     Boolean          @default(false)
  hostLevel             Int              @default(0)
  maxParticipants       Int              @default(0)
  maxConcurrentRooms    Int              @default(0)
  allowedTierVisibility MembershipTier[] @default([])
  grantedByUserId       String?
  grantedAt             DateTime         @default(now())
  expiresAt             DateTime?
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  grantedBy             User?            @relation("CallHostPermissionGrantor", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([canHostGroupCalls, isActive, expiresAt])
  @@index([hostLevel, isActive])
  @@index([grantedByUserId])
}

model GroupHostAccessRequest {
  id               String                       @id @default(cuid())
  userId           String
  status           GroupHostAccessRequestStatus @default(PENDING)
  message          String?
  requestedAt      DateTime                     @default(now())
  reviewedAt       DateTime?
