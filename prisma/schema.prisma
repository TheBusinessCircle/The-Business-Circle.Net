generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String                     @id @default(cuid())
  name                         String?
  email                        String                     @unique
  emailVerified                DateTime?
  verificationEmailLastSentAt  DateTime?
  verificationEmailSendCount   Int                        @default(0)
  image                        String?
  passwordHash                 String?
  role                         Role                       @default(MEMBER)
  memberRoleTag                MemberRoleTag              @default(FOUNDER)
  membershipTier               MembershipTier             @default(FOUNDATION)
  foundingMember               Boolean                    @default(false)
  foundingTier                 MembershipTier?
  foundingPrice                Int?
  foundingClaimedAt            DateTime?
  acceptedTermsAt              DateTime?
  acceptedRulesAt              DateTime?
  acceptedTermsVersion         String?
  acceptedRulesVersion         String?
  suspended                    Boolean                    @default(false)
  suspendedAt                  DateTime?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  accounts                     Account[]
  createdChannels              Channel[]                  @relation("ChannelCreator")
  handledContacts              ContactSubmission[]        @relation("SubmissionHandler")
  submittedContacts            ContactSubmission[]        @relation("SubmissionAuthor")
  hostedEvents                 Event[]                    @relation("EventHost")
  communityComments            CommunityComment[]
  communityCommentLikes        CommunityCommentLike[]
  communityPostLikes           CommunityPostLike[]
  communityPosts               CommunityPost[]
  communityPromptEvents        CommunityPromptEvent[]     @relation("CommunityPromptActor")
  directMessageRequestsSent    DirectMessageRequest[]     @relation("DirectMessageRequestsSent")
  directMessageRequestsReceived DirectMessageRequest[]    @relation("DirectMessageRequestsReceived")
  directMessageThreads         DirectMessageParticipant[]
  directMessagesSent           DirectMessage[]            @relation("DirectMessagesSent")
  directMessageBlocksCreated   DirectMessageBlock[]       @relation("DirectMessageBlocksCreated")
  directMessageBlocksReceived  DirectMessageBlock[]       @relation("DirectMessageBlocksReceived")
  directMessageReportsFiled    DirectMessageReport[]      @relation("DirectMessageReportsFiled")
  directMessageReportsTargetUser DirectMessageReport[]    @relation("DirectMessageReportsTargetUser")
  directMessageReportsResolvedBy DirectMessageReport[]    @relation("DirectMessageReportsResolvedBy")
  winsAuthored                 Win[]                      @relation("WinsAuthored")
  winParticipations            WinParticipant[]
  moderationActionsByAdmin     ModerationAuditLog[]       @relation("ModerationActionsByAdmin")
  messages                     Message[]
  founderServiceRequests       FounderServiceRequest[]
  foundingMembership           FoundingMember?
  foundingReservations         FoundingOfferReservation[]
  completedPendingRegistration PendingRegistration?      @relation("PendingRegistrationCompletedUser")
  memberInvite                 MemberInvite?
  inviteReferralsSent          InviteReferral[]           @relation("InviteReferrer")
  inviteReferralReceived       InviteReferral?            @relation("InviteReferred")
  reputationScore              ReputationScore?
  reputationEvents             ReputationEvent[]
  userBadges                   UserBadge[]
  innerCircleQuestions         InnerCircleQuestion[]      @relation("InnerCircleQuestionAuthor")
  answeredInnerCircleQuestions InnerCircleQuestion[]      @relation("InnerCircleQuestionAnswerer")
  profile                      Profile?
  resourcesAuthored            Resource[]                 @relation("ResourceAuthor")
  resourceReads               ResourceRead[]
  passwordResetTokens          PasswordResetToken[]
  sessions                     Session[]
  subscription                 Subscription?
  createdCallRooms             CallRoom[]                 @relation("CallRoomCreator")
  hostedCallRooms              CallRoom[]                 @relation("CallRoomHost")
  callParticipations           CallParticipant[]
  callHostPermission           CallHostPermission?
  grantedCallHostPermissions   CallHostPermission[]       @relation("CallHostPermissionGrantor")
  groupHostAccessRequests      GroupHostAccessRequest[]   @relation("GroupHostRequestUser")
  reviewedGroupHostRequests    GroupHostAccessRequest[]   @relation("GroupHostRequestReviewer")
  hostedCallSchedules          CallSchedule[]             @relation("CallScheduleHost")
  callAuditLogs                CallAuditLog[]             @relation("CallAuditActor")
  targetedCallAuditLogs        CallAuditLog[]             @relation("CallAuditTarget")
  redeemedDiscounts            BillingDiscount[]          @relation("BillingDiscountRedeemer")

  @@index([role])
  @@index([memberRoleTag])
  @@index([membershipTier])
  @@index([foundingMember])
  @@index([foundingTier])
  @@index([suspended])
  @@index([createdAt])
  @@index([suspended, createdAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedIp String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([createdAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([identifier])
}

model Profile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  headline             String?
  bio                  String?
  location             String?
  experience           String?
  website              String?
  instagram            String?
  linkedin             String?
  tiktok               String?
  facebook             String?
  youtube              String?
  customLinks          String[]  @default([])
  collaborationNeeds   String?
  collaborationOffers  String?
  partnershipInterests String?
  collaborationTags    String[]  @default([])
  isPublic             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  business             Business?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([location])
  @@index([isPublic])
  @@index([updatedAt])
}

model Business {
  id            String          @id @default(cuid())
  profileId     String          @unique
  status        BusinessStatus?
  companyName   String?
  companyNumber String?
  slug          String?         @unique
  description   String?
  industry      String?
  services      String?
  stage         BusinessStage?
  location      String?
  website       String?
  teamSize      Int?
  foundedYear   Int?
  isPublic      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  profile       Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([industry])
  @@index([status])
  @@index([stage])
  @@index([location])
  @@index([isPublic])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  colorHex    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  resources   Resource[]

  @@index([isActive, sortOrder])
}

model Resource {
  id                   String            @id @default(cuid())
  title                String
  slug                 String            @unique
  content              String            @default("") @db.Text
  excerpt              String            @default("")
  tier                 ResourceTier      @default(FOUNDATION)
  category             String            @default("Getting Started")
  type                 ResourceType      @default(CLARITY)
  summary              String
  coverImage           String?
  stage                ResourceStage     @default(STARTUP)
  status               ResourceStatus    @default(DRAFT)
  accessTier           MembershipTier    @default(FOUNDATION)
  mediaType            ResourceMediaType @default(NONE)
  mediaUrl             String?
  categoryId           String?
  authorId             String?
  estimatedReadMinutes Int?
  scheduledFor         DateTime?
  publishedAt          DateTime?
  archivedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  author               User?             @relation("ResourceAuthor", fields: [authorId], references: [id])
  catalogCategory      Category?         @relation(fields: [categoryId], references: [id])
  blocks               ResourceBlock[]
  readStates           ResourceRead[]
  tags                 ResourceTag[]

  @@index([tier])
  @@index([status])
  @@index([scheduledFor])
  @@index([status, tier])
  @@index([status, accessTier])
  @@index([categoryId])
  @@index([authorId])
  @@index([publishedAt])
  @@index([status, publishedAt])
  @@index([createdAt])
}

model ResourceRead {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  readAt     DateTime @default(now())
  updatedAt  DateTime @updatedAt
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId, readAt])
  @@index([resourceId, readAt])
}

model ResourceBlock {
  id         String            @id @default(cuid())
  resourceId String
  type       ResourceBlockType
  heading    String?
  position   Int
  content    Json
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  resource   Resource          @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, position])
  @@index([resourceId, type])
}

model ResourceTag {
  id         String   @id @default(cuid())
  resourceId String
  name       String
  slug       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, slug])
  @@index([resourceId])
  @@index([slug])
  @@index([name])
}

model Channel {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  description           String?
  topic                 String?
  accessTier            MembershipTier         @default(FOUNDATION)
  accessLevel           ChannelAccessLevel     @default(MEMBERS)
  position              Int                    @default(0)
  allowAutomatedPrompts Boolean                @default(true)
  isPrivate             Boolean                @default(false)
  isArchived            Boolean                @default(false)
  createdById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  communityPosts        CommunityPost[]
  promptEvents          CommunityPromptEvent[]
  createdBy             User?                  @relation("ChannelCreator", fields: [createdById], references: [id])
  messages              Message[]

  @@index([accessTier])
  @@index([accessLevel, position])
  @@index([isPrivate])
  @@index([isArchived])
  @@index([isArchived, accessTier, position])
  @@index([createdById])
}

model Message {
  id              String    @id @default(cuid())
  channelId       String
  userId          String
  parentMessageId String?
  content         String
  attachments     Json?
  isEdited        Boolean   @default(false)
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  channel         Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parentMessage   Message?  @relation("MessageReplies", fields: [parentMessageId], references: [id])
  replies         Message[] @relation("MessageReplies")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([userId, createdAt])
  @@index([parentMessageId])
}

model Event {
  id          String           @id @default(cuid())
  title       String
  slug        String?          @unique
  description String?
  accessTier  MembershipTier   @default(FOUNDATION)
  accessLevel EventAccessLevel @default(MEMBERS)
  startAt     DateTime
  endAt       DateTime?
  timezone    String           @default("UTC")
  location    String?
  hostName    String?
  meetingLink String?
  replayUrl   String?
  capacity    Int?
  isCancelled Boolean          @default(false)
  hostId      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  host        User?            @relation("EventHost", fields: [hostId], references: [id])

  @@index([accessTier])
  @@index([accessLevel])
  @@index([startAt, accessTier])
  @@index([hostId])
  @@index([isCancelled])
  @@index([isCancelled, startAt])
}

model CallRoom {
  id                   String            @id @default(cuid())
  type                 CallRoomType
  status               CallRoomStatus    @default(SCHEDULED)
  createdByUserId      String
  hostUserId           String
  title                String
  description          String?
  slug                 String            @unique
  livekitRoomName      String            @unique
  tierVisibility       CallAudienceScope @default(FOUNDATION)
  customTierVisibility MembershipTier[]  @default([])
  maxParticipants      Int
  hostLevelRequired    Int?
  startsAt             DateTime?
  startedAt            DateTime?
  endedAt              DateTime?
  isRecorded           Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  createdBy            User              @relation("CallRoomCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  hostUser             User              @relation("CallRoomHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  participants         CallParticipant[]
  schedule             CallSchedule?
  auditLogs            CallAuditLog[]

  @@index([type, status])
  @@index([hostUserId, status])
  @@index([createdByUserId, createdAt])
  @@index([status, startsAt])
  @@index([tierVisibility, status])
}

model CallParticipant {
  id              String                       @id @default(cuid())
  roomId          String
  userId          String
  role            CallParticipantRole          @default(MEMBER)
  presenceState   CallParticipantPresenceState @default(INVITED)
  livekitIdentity String?
  joinedAt        DateTime?
  leftAt          DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  room            CallRoom                     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId, presenceState])
  @@index([userId, createdAt])
  @@index([livekitIdentity])
}

model CallHostPermission {
  id                    String           @id @default(cuid())
  userId                String           @unique
  canHostGroupCalls     Boolean          @default(false)
  hostLevel             Int              @default(0)
  maxParticipants       Int              @default(0)
  maxConcurrentRooms    Int              @default(0)
  allowedTierVisibility MembershipTier[] @default([])
  grantedByUserId       String?
  grantedAt             DateTime         @default(now())
  expiresAt             DateTime?
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  grantedBy             User?            @relation("CallHostPermissionGrantor", fields: [grantedByUserId], references: [id], onDelete: SetNull)
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([canHostGroupCalls, isActive, expiresAt])
  @@index([hostLevel, isActive])
  @@index([grantedByUserId])
}

model GroupHostAccessRequest {
  id               String                       @id @default(cuid())
  userId           String
  status           GroupHostAccessRequestStatus @default(PENDING)
  message          String?
  requestedAt      DateTime                     @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewNotes      String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  reviewedBy       User?                        @relation("GroupHostRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  user             User                         @relation("GroupHostRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, requestedAt])
  @@index([status, requestedAt])
  @@index([reviewedByUserId, reviewedAt])
}

model CallSchedule {
  id                   String            @id @default(cuid())
  roomId               String?           @unique
  title                String
  description          String?
  hostUserId           String
  startsAt             DateTime
  endsAt               DateTime?
  tierVisibility       CallAudienceScope @default(FOUNDATION)
  customTierVisibility MembershipTier[]  @default([])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  hostUser             User              @relation("CallScheduleHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  room                 CallRoom?         @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([hostUserId, startsAt])
  @@index([startsAt])
  @@index([tierVisibility, startsAt])
}

model CallAuditLog {
  id           String    @id @default(cuid())
  actorUserId  String?
  targetUserId String?
  roomId       String?
  action       String
  metadata     Json?
  createdAt    DateTime  @default(now())
  actorUser    User?     @relation("CallAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser   User?     @relation("CallAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  room         CallRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([roomId, createdAt])
  @@index([action, createdAt])
}

model RealtimeSystemConfig {
  id                            String   @id @default("default")
  globalCallingEnabled          Boolean  @default(true)
  memberHostedGroupCallsEnabled Boolean  @default(false)
  emergencyShutdownEnabled      Boolean  @default(false)
  defaultHostParticipantCap     Int      @default(6)
  founderRoomDefaultCap         Int      @default(30)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model Subscription {
  id                   String                     @id @default(cuid())
  userId               String                     @unique
  stripeCustomerId     String?                    @unique
  stripeCheckoutSessionId String?                 @unique
  stripeSubscriptionId String?                    @unique
  stripeProductId      String?
  stripePriceId        String?
  status               SubscriptionStatus         @default(INCOMPLETE)
  tier                 MembershipTier             @default(FOUNDATION)
  billingInterval      BillingInterval?
  billingVariant       SubscriptionBillingVariant?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean                    @default(false)
  canceledAt           DateTime?
  lastInvoicePaidAt    DateTime?
  lastInvoiceFailedAt  DateTime?
  metadata             Json?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  foundingClaims       FoundingMember[]
  foundingReservations FoundingOfferReservation[]
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tier])
  @@index([status, tier])
  @@index([billingInterval, billingVariant])
  @@index([currentPeriodEnd])
  @@index([updatedAt])
}

model StripeWebhookEvent {
  id                String                  @id
  type              String
  status            StripeWebhookEventStatus @default(PROCESSING)
  processingStartedAt DateTime?
  processedAt       DateTime?
  attemptCount      Int                     @default(1)
  lastError         String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([status, updatedAt])
  @@index([type, createdAt])
}

model PendingRegistration {
  id                    String                             @id @default(cuid())
  email                 String
  fullName              String
  passwordHash          String
  selectedTier          MembershipTier
  billingInterval       PendingRegistrationBillingInterval
  businessName          String?
  businessStatus        BusinessStatus?
  businessStage         BusinessStage?
  companyNumber         String?
  coreAccessConfirmed   Boolean                            @default(false)
  acceptedTermsAt       DateTime?
  acceptedRulesAt       DateTime?
  acceptedTermsVersion  String?
  acceptedRulesVersion  String?
  inviteCode            String?
  status                PendingRegistrationStatus          @default(PENDING)
  stripeCheckoutSessionId String?                          @unique
  stripeCustomerId      String?
  stripeSubscriptionId  String?                            @unique
  completedUserId       String?                            @unique
  expiresAt             DateTime
  createdAt             DateTime                           @default(now())
  updatedAt             DateTime                           @updatedAt
  completedUser         User?                              @relation("PendingRegistrationCompletedUser", fields: [completedUserId], references: [id], onDelete: SetNull)
  foundingReservations  FoundingOfferReservation[]

  @@index([email, createdAt])
  @@index([status, expiresAt])
  @@index([stripeCustomerId])
}

model FoundingOfferSettings {
  id                       String   @id @default("default")
  enabled                  Boolean  @default(true)
  foundationEnabled        Boolean  @default(true)
  innerCircleEnabled       Boolean  @default(true)
  coreEnabled              Boolean  @default(true)
  foundationLimit          Int      @default(50)
  innerCircleLimit         Int      @default(50)
  coreLimit                Int      @default(50)
  foundationClaimed        Int      @default(0)
  innerCircleClaimed       Int      @default(0)
  coreClaimed              Int      @default(0)
  foundationFoundingPrice  Int      @default(15)
  innerCircleFoundingPrice Int      @default(39)
  coreFoundingPrice        Int      @default(74)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model MemberInvite {
  id            String   @id @default(cuid())
  inviterUserId String   @unique
  inviteCode    String   @unique
  createdAt     DateTime @default(now())
  inviterUser   User     @relation(fields: [inviterUserId], references: [id], onDelete: Cascade)

  @@index([inviteCode])
  @@index([createdAt])
}

model InviteReferral {
  id               String         @id @default(cuid())
  inviterUserId    String
  referredUserId   String         @unique
  subscriptionTier MembershipTier
  joinedAt         DateTime       @default(now())
  inviterUser      User           @relation("InviteReferrer", fields: [inviterUserId], references: [id], onDelete: Cascade)
  referredUser     User           @relation("InviteReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([inviterUserId, joinedAt])
  @@index([subscriptionTier, joinedAt])
}

model ReputationScore {
  id          String   @id @default(cuid())
  userId      String   @unique
  score       Int      @default(0)
  lastUpdated DateTime @default(now()) @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReputationEvent {
  id        String              @id @default(cuid())
  userId    String
  eventType ReputationEventType
  points    Int
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  icon        String
  priority    Int
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]

  @@index([priority])
}

model UserBadge {
  id             String   @id @default(cuid())
  userId         String
  badgeId        String
  awardedAt      DateTime @default(now())
  awardedByAdmin Boolean  @default(false)
  badge          Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId, awardedAt])
  @@index([badgeId])
}

model FoundingMember {
  id             String         @id @default(cuid())
  userId         String         @unique
  tier           MembershipTier
  foundingPrice  Int
  claimedAt      DateTime       @default(now())
  subscriptionId String?
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier, claimedAt])
  @@index([claimedAt])
  @@index([subscriptionId])
}

model FoundingOfferReservation {
  id                String                    @id @default(cuid())
  userId            String?
  pendingRegistrationId String?
  tier              MembershipTier
  foundingPrice     Int
  source            FoundingReservationSource @default(CHECKOUT)
  status            FoundingReservationStatus @default(ACTIVE)
  checkoutSessionId String?                   @unique
  subscriptionId    String?
  expiresAt         DateTime
  claimedAt         DateTime?
  releasedAt        DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  pendingRegistration PendingRegistration?    @relation(fields: [pendingRegistrationId], references: [id], onDelete: Cascade)
  subscription      Subscription?             @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user              User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier, status, expiresAt])
  @@index([userId, status, expiresAt])
  @@index([pendingRegistrationId, status, expiresAt])
  @@index([checkoutSessionId])
  @@index([subscriptionId])
}

model InnerCircleQuestion {
  id           String    @id @default(cuid())
  userId       String
  answeredById String?
  question     String
  answer       String?
  isAnswered   Boolean   @default(false)
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
