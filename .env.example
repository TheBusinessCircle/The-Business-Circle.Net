# BCN Updates automation
# - BCN_COMMUNITY_AUTOMATION_ENABLED=false disables both manual and opportunistic BCN publishing
# - BCN_COMMUNITY_SOURCE_URL is legacy single-source mode
# - BCN_COMMUNITY_SOURCE_URLS is the preferred multi-source mode and accepts a comma-separated list of RSS, Atom, or JSON feed URLs
# - COMMUNITY_AUTOMATION_AUTHOR_ID should be the real user id that owns automated BCN posts in production
# - all BCN Updates content shown to members is normalized to English; likely non-English items are skipped
# - BCN_COMMUNITY_LOOKBACK_HOURS should stay at 24 so the feed stays focused on the last day's useful business stories
# - production should hit /api/internal/community/bcn-updates/run every 5 minutes with COMMUNITY_AUTOMATION_SECRET or CRON_SECRET
# - use only free public feeds here, for example:
#   https://feeds.bbci.co.uk/news/business/rss.xml
#   https://feeds.bbci.co.uk/news/technology/rss.xml
#   https://www.reutersagency.com/feed/?best-regions=world&post_type=best
# - test locally with /api/internal/community/bcn-updates/run?secret=YOUR_SECRET
BCN_COMMUNITY_AUTOMATION_ENABLED="true"
BCN_COMMUNITY_SOURCE_URL=""
BCN_COMMUNITY_SOURCE_URLS="https://feeds.bbci.co.uk/news/business/rss.xml,https://feeds.bbci.co.uk/news/technology/rss.xml,https://www.reutersagency.com/feed/?best-regions=world&post_type=best"
BCN_COMMUNITY_SOURCE_NAME="BCN Source"
BCN_COMMUNITY_LOOKBACK_HOURS="24"
BCN_COMMUNITY_AUTOMATION_THROTTLE_MS="300000"
BCN_COMMUNITY_MAX_POSTS_PER_RUN="2"
# Optional explicit path to Chrome/Chromium for BCN source-page screenshots.
# If omitted, the server will try common Chrome/Chromium locations automatically.
BCN_SOURCE_PREVIEW_CHROME_PATH=""
RESOURCE_AUTOMATION_SECRET="change-this-secret"
RESOURCE_SCHEDULE_TIMEZONE="Europe/London"
RESOURCE_FOUNDATION_PUBLISH_TIMES="09:00,13:00,18:00"
RESOURCE_INNER_PUBLISH_TIMES="10:30,14:30,19:30"
RESOURCE_CORE_PUBLISH_TIMES="12:00,16:00,20:30"
RESOURCE_AUTOMATION_THROTTLE_MS="300000"
RESOURCE_GENERATION_PROVIDER="openai"
OPENAI_API_KEY=""
RESOURCE_CONTENT_MODEL="gpt-5.4-mini"
RESOURCE_IMAGE_MODEL="gpt-image-2"
RESOURCE_IMAGE_FALLBACK_MODEL="gpt-image-1"
RESOURCE_IMAGE_SIZE="1024x1024"
RESOURCE_IMAGE_QUALITY="medium"
RESOURCE_DAILY_FOUNDATION_PUBLISH_TIME="09:00"
RESOURCE_DAILY_INNER_PUBLISH_TIME="13:00"
RESOURCE_DAILY_CORE_PUBLISH_TIME="17:00"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_LINKEDIN_URL=""
NEXT_PUBLIC_INSTAGRAM_URL=""
