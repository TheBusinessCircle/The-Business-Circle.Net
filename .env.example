COMMUNITY_PROMPT_AUTHOR_ID=""
# BCN Updates automation
# - BCN_COMMUNITY_AUTOMATION_ENABLED=false disables both manual and opportunistic BCN publishing
# - BCN_COMMUNITY_SOURCE_URL is legacy single-source mode
# - BCN Intelligence now ships with a registry of approved RSS-first sources
# - BCN_COMMUNITY_SOURCE_URLS is legacy/additional multi-source mode and accepts a comma-separated list of RSS, Atom, or JSON feed URLs
# - BCN_INTELLIGENCE_EXTRA_SOURCE_URLS adds extra approved feeds without replacing the registry
# - COMMUNITY_AUTOMATION_AUTHOR_ID should be the real user id that owns automated BCN posts in production
# - all BCN Updates content shown to members is normalized to English; likely non-English items are skipped
# - BCN_COMMUNITY_LOOKBACK_HOURS should stay at 24 so the feed stays focused on the last day's useful business stories
# - production should hit /api/cron/intelligence-refresh every 5 minutes with INTELLIGENCE_CRON_SECRET or CRON_SECRET
# - use only free public feeds here, for example:
#   https://feeds.bbci.co.uk/news/business/rss.xml
#   https://feeds.bbci.co.uk/news/technology/rss.xml
#   https://www.reutersagency.com/feed/?best-regions=world&post_type=best
# - test locally with /api/internal/community/bcn-updates/run?secret=YOUR_SECRET
BCN_COMMUNITY_AUTOMATION_ENABLED="true"
BCN_COMMUNITY_SOURCE_URL=""
BCN_COMMUNITY_SOURCE_URLS=""
BCN_INTELLIGENCE_EXTRA_SOURCE_URLS=""
# Optional emergency switch for legacy feed-only mode. Leave true in production.
BCN_INTELLIGENCE_SOURCE_REGISTRY_ENABLED="true"
BCN_COMMUNITY_SOURCE_NAME="BCN Source"
BCN_COMMUNITY_LOOKBACK_HOURS="24"
BCN_COMMUNITY_AUTOMATION_THROTTLE_MS="300000"
BCN_COMMUNITY_MAX_POSTS_PER_RUN="6"
BCN_INTELLIGENCE_SOURCE_TIMEOUT_MS="7000"
# Optional screenshot provider URL template. Use {url} where the encoded source URL should be inserted.
# Leave blank unless you have a compliant provider configured.
BCN_SOURCE_PREVIEW_SCREENSHOT_URL_TEMPLATE=""
