# Example only. Do not copy certificate paths or upstream ports without review.
# Place the maps in the http {} context.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream business_circle_next {
    server 127.0.0.1:3000;
    keepalive 32;
}

upstream circle_card_next {
    server 127.0.0.1:3200;
    keepalive 32;
}

# Unknown HTTP hosts never reach Next.js.
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    return 421;
}

server {
    listen 80;
    listen [::]:80;
    server_name thebusinesscircle.net www.thebusinesscircle.net circlecard.co.uk www.circlecard.co.uk;
    return 308 https://$host$request_uri;
}

# Unknown HTTPS hosts require a deliberately configured fallback certificate.
server {
    listen 443 ssl default_server;
    listen [::]:443 ssl default_server;
    server_name _;
    ssl_certificate /path/to/reviewed/default/fullchain.pem;
    ssl_certificate_key /path/to/reviewed/default/privkey.pem;
    return 421;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name thebusinesscircle.net www.thebusinesscircle.net;

    ssl_certificate /path/to/reviewed/bcn/fullchain.pem;
    ssl_certificate_key /path/to/reviewed/bcn/privkey.pem;

    # Stripe must continue posting to this BCN upstream. Never redirect this location.
    location = /api/stripe/webhook {
        client_max_body_size 1m;
        proxy_pass http://business_circle_next;
        proxy_http_version 1.1;
        proxy_request_buffering on;
        proxy_buffering on;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Connection "";
    }

    location / {
        proxy_pass http://business_circle_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
        proxy_buffering off;
        proxy_redirect off;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name circlecard.co.uk www.circlecard.co.uk;

    ssl_certificate /path/to/reviewed/circle-card/fullchain.pem;
    ssl_certificate_key /path/to/reviewed/circle-card/privkey.pem;

    # Defence in depth: Circle Card never proxies the shared Stripe webhook.
    location = /api/stripe/webhook {
        return 404;
    }

    location ^~ /api/webhooks/resend/inbound {
        return 404;
    }

    location ^~ /api/cron/ {
        return 404;
    }

    location = /api/cron {
        return 404;
    }

    location ^~ /api/internal/ {
        return 404;
    }

    location = /api/internal {
        return 404;
    }

    location / {
        proxy_pass http://circle_card_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 300s;
        proxy_buffering off;
        proxy_redirect off;
    }
}
