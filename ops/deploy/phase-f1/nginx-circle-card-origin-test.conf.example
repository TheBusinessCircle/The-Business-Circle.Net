worker_processes 1;
pid __STATE_ROOT__/nginx.pid;
error_log __STATE_ROOT__/error.log notice;

events { worker_connections 128; }

http {
    access_log __STATE_ROOT__/access.log;
    upstream phase_f1_circle_card_test { server 127.0.0.1:3200; }

    server {
        listen 127.0.0.1:8443 ssl default_server;
        server_name _;
        ssl_certificate __CERTIFICATE__;
        ssl_certificate_key __PRIVATE_KEY__;
        return 421;
    }

    server {
        listen 127.0.0.1:8443 ssl;
        server_name circlecard.co.uk;
        ssl_certificate __CERTIFICATE__;
        ssl_certificate_key __PRIVATE_KEY__;

        location = /api/stripe/webhook { return 404; }
        location = /api/webhooks/resend/inbound { return 404; }
        location ^~ /api/webhooks/resend/inbound/ { return 404; }
        location = /api/cron { return 404; }
        location ^~ /api/cron/ { return 404; }
        location = /api/internal { return 404; }
        location ^~ /api/internal/ { return 404; }

        location / {
            proxy_pass http://phase_f1_circle_card_test;
            proxy_http_version 1.1;
            proxy_set_header Host circlecard.co.uk;
            proxy_set_header X-Forwarded-Host circlecard.co.uk;
            proxy_set_header X-Forwarded-Proto https;
            proxy_set_header X-Real-IP 127.0.0.1;
            proxy_set_header X-Forwarded-For 127.0.0.1;
            proxy_redirect off;
        }
    }
}
